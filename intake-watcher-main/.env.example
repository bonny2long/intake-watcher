# Intake Watcher local development defaults
DATA_ROOT=data
INTAKE_MODE=hybrid
STABILITY_SECONDS=1200
POLL_SECONDS=300
REQUIRE_READY_MARKER=false
READY_MARKERS=READY.txt,.done
ALLOW_SINGLE_FILE_PROMOTION=true
COLLISION_POLICY=block

# Safety posture. This scaffold does not delete files either way.
DESTRUCTIVE_ACTIONS_ENABLED=false

# Dashboard/server behavior
AUTO_RUN=true
DASHBOARD_PORT=8091
